# =============================================================================
# Cariak .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime output — DO NOT commit research results (except examples)
# -----------------------------------------------------------------------------
docs/cariak/
!docs/examples/

# -----------------------------------------------------------------------------
# JSON files — DO NOT commit runtime JSON (except references.json templates and package.json)
# -----------------------------------------------------------------------------
*.json
!references/*.json
!package.json
!package-lock.json
!tsconfig.json

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt
.venv/
venv/
env/
.python-version

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn-integrity
.eslintcache
.cache
.parcel-cache
.next/
.nuxt/
.grunt/
.outputs/

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.fseventsd

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.tmp
*.temp
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Linux
# -----------------------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# IDEs & Editors
# -----------------------------------------------------------------------------
# JetBrains (IntelliJ, WebStorm, PyCharm, etc.)
.idea/
*.iml
*.ipr
*.iws
out/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
auto-save-list
tramp
.\#*

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

# -----------------------------------------------------------------------------
# Cariak-specific
# -----------------------------------------------------------------------------
# Downloaded papers (from paper-search-mcp)
downloads/
# Temp working directory
tmp/
temp/
